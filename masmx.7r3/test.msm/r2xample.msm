	$path		../smaragd.68k
	$include	coldfire.def
	$include	express.def
	$include	fpxpress.def
	$path
	$include	espresso.def
	$include	ieee754.def

f	$func	*
"$ieee64"* $name 111
"$UP"*	$equf	$azlit(ieee754_64 f(1))
	$return	$UP
	$end

$(4:16384,a5/$literal)

one	$res	8
two	$res	8
three	$res	8

westward $res	2
ho	$res	2

$(5:16384+1024)
rastore	$res	8
rapointer $res	4

$(1:131072,pc/$azlit)

fp_routine
	lea		$a(one), a5
	$xqt_fp,$ieee64	one*1.75*+1200000*two/3.0*-625000-three

	$xqt_fp		d5+fp6+a2@+"-(a4)"+"a3@+"*(*rapointer)/rastore

	$plist	3
	$xqt_fp		(westward w)+(ho w)*(*rapointer s)
	$plist

	rts
