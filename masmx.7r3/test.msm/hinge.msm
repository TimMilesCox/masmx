	$word	32
	$quantum 8
	$awidth	32:64

	$set_option	"i"	.	test of sign extended addressing

yabass	$equ	000FFC00000000000

$(5:0FFFFFFF8:*yabass)
one	+	99
two	+	100
three	+	101
four	+	102

yabiggie1	+	yabass-8
yabiggie2	+       yabass-4
yabiggie3	+       yabass-0
yabiggie4	+       yabass+4

	+	one
	+	two
	+	three
	+	four
	+	$a
