
	$path		../smaragd.68k
	$include	coldfire.def

.text	$equ	0

$(.text:524288,pc)

i2string
	divu.w	#10000, d0
	moveq	#0, d1
	move.w	d0, d1
	divu.w	#10000, d1
	move.l	(table, pc, d1.w*4), (a0)+
	swap	d1
	move.l	(table, pc, d1.w*4), (a0)+
	swap	d0
	move.l	(table, pc, d0.w*4), (a0)+
	rts

table
	$list	0
thousands	$do	10,|
hundreds	$do	10,|
tens		$do	10,|
units		$do	10,	'0'+thousands-1, '0'+hundreds-1, '0'+tens-1, '0'+units-1L

