	$word		32
	$quantum	8

ABSOLUTE	$equ	-4096
MINUS8		$equ	-8
$(5:*1)
relocatable	$res	1
$(6:06000)

	+	relocatable*/-16	. shift right algebraic 16 positions after relocation
					. signed range check after reloction and shift

	+	relocatable*/-0		. shift no positions
					. signed range check after relocation

	+	relocatable*/(-16)	. shift right algebraic 16 positions after relocation
					. signed range check after relocation and shift

	+	ABSOLUTE*/MINUS8	. shift right algebraic 8 positions at assembly time
	+	ABSOLUTE*/-8		. shift right algebraic 8 positions at assembly time
	+	0FFFFF000/*8		. shift right logical 8 positions at assembly time	

	+	relocatable/*8		. shift right logical 8 positions after relocation
					. unsigned range check after relocation and shift

	+	relocatable+EXTERNAL*/-12 . shift right algebraic 12 positions after relocation
					. signed range check after relocation and shift

	+	relocatable*/MINUS8	. shift right algebraic 8 positions after relocation
					. signed range check after relocation and shift
