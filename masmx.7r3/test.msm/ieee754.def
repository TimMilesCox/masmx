
	$floating_point	32
	$characteristic	9
	$characteristic,64 12
	$characteristic,128 16
	

fieee754_32 $form 1, 8, 23
fieee754_64 $form 1, 11, 52
fieee754_128 $form 1, 15, 112

p       $proc
ieee754_32* $name 0

tag     $set,33	 p(1,1)
signs   $set    tag*/192-33*/-191
tag     $set    tag--(signs**((1*/33)-1))    
characteristic $set (tag/*24)-2
	$do	tag**((1*/33-1)-1)=0,characteristic	$set	0

	$do	$o('V'),	$snap	2

        $nop	normalising bit truncated

        fieee754_32 signs, characteristic, tag
        $end


p       $proc
ieee754_64* $name

tag     $set,65	p(1,1)
signs	$set    tag*/192-65*/-191
tag     $set	tag--(signs**((1*/65)-1))
characteristic $set (tag/*53)-2
	$do	tag**((1*/65-1)-1)=0,characteristic	$set	0

	$do	$o('V'),	$snap	2

        $nop	normalising bit truncated

        fieee754_64 signs, characteristic, tag
        $end

p	$proc
ieee754_128* $name

tag	$set,129	p(1, 1)
signs	$set	tag*/192-129*/-191
tag	$set	tag--(signs**((1*/129)-1))
characteristic $set (tag/*113)-2
	$do	tag**((1*/129-1)-1)=0,characteristic	$set	0

	$do	$o('V'),	$snap	2

	$nop	normalising bit truncated

	fieee754_128	signs, characteristic, tag
	$end

